{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/financeapp-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true
        }
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=your-production-db-host;Port=5432;Database=financeapp;Username=your-db-user;Password=your-strong-password",
    "Redis": "your-production-redis-host:6379,password=your-redis-password"
  },
  "JwtSettings": {
    "SecretKey": "CHANGE-THIS-TO-A-SECURE-RANDOM-KEY-MINIMUM-64-CHARACTERS-FOR-PRODUCTION-USE",
    "Issuer": "FinanceApp",
    "Audience": "FinanceAppUsers"
  },
  "AllowedHosts": "your-domain.com,www.your-domain.com",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:80"
      },
      "Https": {
        "Url": "https://0.0.0.0:443",
        "Certificate": {
          "Path": "/https/certificate.pfx",
          "Password": "your-certificate-password"
        }
      }
    }
  },
  "RateLimiting": {
    "PermitLimit": 50,
    "WindowMinutes": 1
  },
  "Cors": {
    "AllowedOrigins": [
      "https://your-frontend.com",
      "https://www.your-frontend.com"
    ]
  }
}
