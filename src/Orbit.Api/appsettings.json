{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=financeapp.db"
  },
  "JwtSettings": {
    "Issuer": "FinanceApp",
    "Audience": "FinanceAppUsers"
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "https://localhost:3000"
  ],
  "AllowedHosts": "*",
  "Briefing": {
    "Hour": 8
  }
}
