# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=financeapp
DB_USER=postgres
DB_PASSWORD=change-this-password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration - MUST change in production
JWT_SECRET_KEY=change-this-to-a-strong-random-key-minimum-32-characters-required
JWT_ISSUER=FinanceApp
JWT_AUDIENCE=FinanceAppUsers

# Application Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# Seed admin password (only used when ASPNETCORE_ENVIRONMENT=Development and no users exist)
SEED_ADMIN_PASSWORD=change-this-Admin@123
