# ===========================================
# Orbit Finance App - Environment Variables
# ===========================================
# Copy this file to .env and fill in all required values
# cp .env.example .env

# Database Configuration
DB_USER=postgres
DB_PASSWORD=          # REQUIRED: Set a strong password
DB_NAME=orbit

# JWT Configuration
JWT_SECRET_KEY=       # REQUIRED: Minimum 32 characters, use a random string
JWT_ISSUER=Orbit
JWT_AUDIENCE=OrbitUsers

# Seed admin password (only used on first run when no users exist)
SEED_ADMIN_PASSWORD=  # REQUIRED: Set a strong admin password

# Application Configuration
ASPNETCORE_ENVIRONMENT=Development

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Alert Evaluation Interval in hours (default: 6)
ALERT_EVAL_INTERVAL=6
